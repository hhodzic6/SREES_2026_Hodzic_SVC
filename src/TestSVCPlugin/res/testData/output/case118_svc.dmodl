ODEs:
	// SVC Type I dynamics on bus 11 (Milano eq. 19.3)
	vM_11' = (KM_11*v_11 - vM_11)/TM_11
	sigma_11' = -KD_11 + K_11*T1_11/(T2_11*TM_11)*(vM_11 - KM_11*v_11) + K_11/T2_11*(vref_11 - vM_11)
	// SVC Type II dynamics on bus 16 (Milano eq. 19.4)
	bSvc_16' = (Kr_16*(vref_16 - v_16) - bSvc_16)/Tr_16

NLEs:
	// Node 1 - PV
	v_1*v_1*absY_1_1*cos(angleY_1_1) + v_1*v_2*absY_1_2*cos(phi_1-phi_2-angleY_1_2) + v_1*v_3*absY_1_3*cos(phi_1-phi_3-angleY_1_3) - P_1_inj_spec = 0
