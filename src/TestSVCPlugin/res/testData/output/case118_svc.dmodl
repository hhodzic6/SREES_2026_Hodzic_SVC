	v_117*v_12*absY_117_12*cos(phi_117-phi_12-angleY_117_12) + v_117*v_117*absY_117_117*cos(angleY_117_117) - P_117_inj_spec = 0
	v_117*v_12*absY_117_12*sin(phi_117-phi_12-angleY_117_12) - v_117*v_117*absY_117_117*sin(angleY_117_117) - Q_117_inj_spec = 0
	// Node 118 - PQ
	v_118*v_75*absY_118_75*cos(phi_118-phi_75-angleY_118_75) + v_118*v_76*absY_118_76*cos(phi_118-phi_76-angleY_118_76) + v_118*v_118*absY_118_118*cos(angleY_118_118) - P_118_inj_spec = 0
	v_118*v_75*absY_118_75*sin(phi_118-phi_75-angleY_118_75) + v_118*v_76*absY_118_76*sin(phi_118-phi_76-angleY_118_76) - v_118*v_118*absY_118_118*sin(angleY_118_118) - Q_118_inj_spec = 0

end
